{
  "name": "jamesbrink-website",
  "type": "module",
  "version": "1.0.0",
  "author": "James Brink <brink.james@gmail.com>",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore dist --ignore jamesbrink.github.io --ignore playwright-report --ignore test-results",
    "lint:all": "bun run lint && bun run lint:md",
    "test": "vitest",
    "test:run": "vitest run",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "clsx": "^2.1.1",
    "openseadragon": "^6.0.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/openseadragon": "^6.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
