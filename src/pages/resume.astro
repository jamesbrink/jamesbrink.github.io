const education = [
  { title: 'Certification, CCNA', org: 'Cisco Systems, 2007' },
  { title: 'Diploma, Network Switching Systems', org: 'General Dynamics, 2001' },
  { title: 'Diploma, Satellite Communications', org: 'Department of the Army, 2001' },
];
---

<SimpleLayout
  title="Resume"
  intro="James Brink — Site Reliability Engineer & Infrastructure Architect with decades of experience in cloud infrastructure, automation, and DevOps."
>
  <div class="space-y-20">
    <!-- Technical Expertise -->
    <section>
      <h2 class="text-heading text-2xl font-bold tracking-tight">Technical Expertise</h2>
      <div class="mt-6 flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <span class="bg-pill text-body inline-flex items-center rounded-full px-3 py-1 text-sm font-medium">
              {skill}
            </span>
          ))
        }
      </div>
    </section>

    <!-- Experience -->
    <section>
      <h2 class="text-heading text-2xl font-bold tracking-tight">Experience</h2>
      <p class="text-muted mt-3 text-sm">
        Some roles overlap — I've frequently run concurrent full-time and consulting/contract
        engagements. Listed most recent first.
      </p>
      <div class="mt-6 space-y-8">
        {
          experience.map((job) => (
            <div class="group border-hairline hover:border-edge relative rounded-2xl border p-6 transition">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-heading text-base font-semibold">{job.company}</h3>
                  <p class="text-accent text-sm">{job.role}</p>
                </div>
                <time class="text-muted text-sm">{job.date}</time>
              </div>
              <p class="text-body mt-4 text-sm">{job.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Open Source Projects -->
    <section>
      <h2 class="text-heading text-2xl font-bold tracking-tight">Open Source Projects</h2>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          projects.map((project) => (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group border-hairline hover:border-edge relative rounded-2xl border p-6 transition"
            >
              <h3 class="text-heading group-hover:text-link text-base font-semibold">
                {project.name}
              </h3>
              <p class="text-body mt-2 text-sm">{project.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Education -->
    <section>
      <h2 class="text-heading text-2xl font-bold tracking-tight">Education & Certifications</h2>
      <div class="mt-6 space-y-4">
        {
          education.map((item) => (
            <div class="border-emission flex flex-col gap-1 border-l-2 pl-4 sm:flex-row sm:items-center sm:gap-2">
              <span class="text-heading font-semibold">{item.title}</span>
              <span class="text-body">— {item.org}</span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Download Button -->
    <div class="flex justify-center">
      <Button href="/JamesBrink-Resume.pdf" variant="secondary" target="_blank">
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" class="h-4 w-4 stroke-current">
          <path
            d="M4.75 8.75 8 12.25m0 0 3.25-3.5M8 12.25v-8.5"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Download Resume
      </Button>
    </div>
  </div>
</SimpleLayout>
