---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Container class="flex h-full items-center pt-16 sm:pt-32">
    <div class="flex flex-col items-center">
      <p class="text-muted text-base font-semibold">404</p>
      <h1 class="text-heading mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
        Page not found
      </h1>
      <p class="text-body mt-4 text-base">
        This route 404'd harder than a production deploy at 2am. The page you're after doesn't exist
        (or I broke it — statistically likely).
      </p>
      <Button href="/" variant="secondary" class="mt-4"> Go back home </Button>
    </div>
  </Container>
</BaseLayout>
