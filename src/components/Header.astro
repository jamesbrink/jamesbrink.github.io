---
import Container from './Container.astro';
import clsx from 'clsx';
import { navItems } from '../data/navigation';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const pathname = Astro.url.pathname;
const isHomePage = pathname === '/';

// Trailing-slash-insensitive active-link check ('/blog/' matches '/blog/tag/x/')
function isActivePath(href: string): boolean {
  const current = pathname.replace(/\/+$/, '') || '/';
  const target = href.replace(/\/+$/, '') || '/';
  return current === target || current.startsWith(target + '/');
}
---

<header class={clsx('pointer-events-none relative z-50 flex flex-none flex-col', className)}>
  {
    isHomePage && (
      <>
        <div class="order-last mt-[calc(theme(spacing.16)-theme(spacing.3))]" />
        <Container class="top-0 order-last -mb-3 pt-3">
          <div class="top-[var(--avatar-top,theme(spacing.3))] w-full">
            <div class="relative">
              <a href="/" aria-label="Home" class="pointer-events-auto block h-16 w-16 origin-left">
                <img
                  src="/images/avatar.jpg"
                  alt="James Brink"
                  class="bg-pill h-16 w-16 rounded-full object-cover"
                />
              </a>
            </div>
          </div>
        </Container>
      </>
    )
  }
  <div class="top-0 z-10 h-16 pt-6">
    <Container>
      <div class="relative flex gap-4">
        <div class="flex flex-1">
          {
            !isHomePage && (
              <div class="ring-hairline bg-card/90 h-10 w-10 rounded-full p-0.5 shadow-lg ring-1 backdrop-blur-sm">
                <a href="/" aria-label="Home" class="pointer-events-auto">
                  <img
                    src="/images/avatar.jpg"
                    alt="James Brink"
                    class="bg-pill h-9 w-9 rounded-full object-cover"
                  />
                </a>
              </div>
            )
          }
        </div>
        <div class="flex flex-1 justify-end md:justify-center">
          <!-- Mobile Navigation -->
          <div class="pointer-events-auto md:hidden">
            <button
              type="button"
              class="group ring-hairline bg-card/90 text-heading flex items-center rounded-full px-4 py-2 text-sm font-medium shadow-lg ring-1 backdrop-blur-sm"
              aria-label="Toggle navigation"
              id="mobile-menu-button"
            >
              Menu
              <svg
                viewBox="0 0 8 6"
                aria-hidden="true"
                class="stroke-muted group-hover:stroke-subtle ml-3 h-auto w-2"
              >
                <path
                  d="M1.75 1.75 4 4.25l2.25-2.5"
                  fill="none"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>

          <!-- Desktop Navigation -->
          <nav class="pointer-events-auto hidden md:block">
            <ul
              class="ring-hairline bg-card/90 text-heading flex rounded-full px-3 text-sm font-medium shadow-lg ring-1 backdrop-blur-sm"
            >
              {
                navItems.map((item) => {
                  const isActive = isActivePath(item.href);
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={clsx(
                          'relative block px-3 py-2 transition',
                          isActive ? 'text-link' : 'text-heading hover:text-link'
                        )}
                      >
                        {item.label}
                        {isActive && (
                          <span class="from-emission/0 via-emission/40 to-emission/0 absolute inset-x-1 -bottom-px h-px bg-gradient-to-r" />
                        )}
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </nav>
        </div>
        <div class="flex justify-end md:flex-1">
          <div class="pointer-events-auto">
            <button
              type="button"
              aria-label="Toggle theme"
              class="group ring-hairline bg-card/90 rounded-full px-3 py-2 shadow-lg ring-1 backdrop-blur-sm transition"
              id="theme-toggle"
            >
              <!-- Sun icon (shown in light mode) -->
              <svg
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="stroke-muted group-hover:fill-gold group-hover:stroke-emission light:block hidden h-6 w-6 fill-[var(--ink-200)] transition"
              >
                <path
                  d="M8 12.25A4.25 4.25 0 0 1 12.25 8v0a4.25 4.25 0 0 1 4.25 4.25v0a4.25 4.25 0 0 1-4.25 4.25v0A4.25 4.25 0 0 1 8 12.25v0Z"
                ></path>
                <path
                  d="M12.25 3v1.5M21.5 12.25H20M18.791 18.791l-1.06-1.06M18.791 5.709l-1.06 1.06M12.25 20v1.5M4.5 12.25H3M6.77 6.77 5.709 5.709M6.77 17.73l-1.061 1.061"
                  fill="none"></path>
              </svg>
              <!-- Moon icon (shown in dark mode / default) -->
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
                class="stroke-muted group-hover:stroke-emission-hi light:hidden block h-6 w-6 fill-[var(--ink-700)] transition group-hover:fill-[var(--ink-600)]"
              >
                <path
                  d="M17.25 16.22a6.937 6.937 0 0 1-9.47-9.47 7.451 7.451 0 1 0 9.47 9.47ZM12.75 7C17 7 17 2.75 17 2.75S17 7 21.25 7C17 7 17 11.25 17 11.25S17 7 12.75 7Z"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </Container>
  </div>
</header>

{isHomePage && <div class="flex-none" style="height: var(--content-offset)" />}

<!-- Mobile Menu (hidden by default) -->
<div
  id="mobile-menu"
  class="ring-hairline bg-card fixed inset-x-4 top-8 z-50 hidden origin-top rounded-3xl p-8 ring-1"
>
  <div class="flex flex-row-reverse items-center justify-between">
    <button type="button" aria-label="Close menu" class="-m-1 p-1" id="mobile-menu-close">
      <svg viewBox="0 0 24 24" aria-hidden="true" class="text-muted h-6 w-6">
        <path
          d="m17.25 6.75-10.5 10.5M6.75 6.75l10.5 10.5"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>
    <h2 class="text-body text-sm font-medium">Navigation</h2>
  </div>
  <nav class="mt-6">
    <ul class="divide-hairline text-heading -my-2 divide-y text-base">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} class="block py-2 text-inherit">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<!-- Mobile Menu Backdrop -->
<div id="mobile-menu-backdrop" class="fixed inset-0 z-40 hidden bg-black/60 backdrop-blur-sm"></div>

<script>
  // Theme toggle — dark-first, so we toggle the `.light` class.
  function initTheme() {
    const themeToggle = document.getElementById('theme-toggle');
    if (!themeToggle) return;

    themeToggle.addEventListener('click', () => {
      const isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
    });
  }

  // Mobile menu
  function initMobileMenu() {
    const menuButton = document.getElementById('mobile-menu-button');
    const menuClose = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');

    if (!menuButton || !menuClose || !menu || !backdrop) return;

    function openMenu() {
      menu!.classList.remove('hidden');
      backdrop!.classList.remove('hidden');
    }

    function closeMenu() {
      menu!.classList.add('hidden');
      backdrop!.classList.add('hidden');
    }

    menuButton.addEventListener('click', openMenu);
    menuClose.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);
  }

  // Initialize on page load
  document.addEventListener('astro:page-load', () => {
    initTheme();
    initMobileMenu();
  });

  // Also run on initial load
  initTheme();
  initMobileMenu();
</script>
