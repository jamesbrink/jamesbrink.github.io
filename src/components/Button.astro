---
import clsx from 'clsx';

interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  target?: string;
  class?: string;
}

const { variant = 'primary', href, target, class: className } = Astro.props;

const variantStyles = {
  primary:
    'bg-emission font-semibold text-on-solid shadow-[var(--shadow-glow)] hover:bg-emission-hi active:opacity-85',
  secondary:
    'bg-white/5 font-medium text-strong ring-1 ring-hairline hover:bg-white/10 active:opacity-70',
};

const baseStyles =
  'inline-flex items-center gap-2 justify-center rounded-md py-2 px-3 text-sm outline-offset-2 transition active:transition-none';
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={target === '_blank' ? 'noopener noreferrer' : undefined}
      class={clsx(baseStyles, variantStyles[variant], className)}
    >
      <slot />
    </a>
  ) : (
    <button class={clsx(baseStyles, variantStyles[variant], className)}>
      <slot />
    </button>
  )
}
