---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/Container.astro';
import Prose from '../components/Prose.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../lib/utils';

interface SeriesPost {
  slug: string;
  title: string;
  order: number;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  series?: string;
  seriesOrder?: number;
}

const {
  title,
  description,
  date,
  updatedDate,
  heroImage,
  tags = [],
  series,
  seriesOrder,
} = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Get series posts if this article is part of a series
let seriesPosts: SeriesPost[] = [];
if (series) {
  const allPosts = await getCollection('blog');
  seriesPosts = allPosts
    .filter((post) => post.data.series === series && !post.data.draft)
    .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0))
    .map((post) => ({
      slug: post.id,
      title: post.data.title,
      order: post.data.seriesOrder || 0,
    }));
}
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishDate={date}
  updatedDate={updatedDate}
  image={heroImage}
  tags={tags}
>
  <Container class="mt-16 lg:mt-32">
    <div class="xl:relative">
      <div class="mx-auto max-w-2xl">
        <a
          href="/blog/"
          aria-label="Go back to articles"
          class="group bg-card ring-hairline hover:border-edge mb-8 flex h-10 w-10 items-center justify-center rounded-full shadow-md ring-1 transition lg:absolute lg:-left-5 lg:-mt-2 lg:mb-0 xl:-top-1.5 xl:left-0 xl:mt-0"
        >
          <svg
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            class="stroke-muted group-hover:stroke-subtle h-4 w-4 transition"
          >
            <path
              d="M7.25 11.25 3.75 8m0 0 3.5-3.25M3.75 8h8.5"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <article>
          <header class="flex flex-col">
            <h1 class="text-heading mt-6 text-4xl font-bold tracking-tight sm:text-5xl">
              {title}
            </h1>
            <time
              datetime={date.toISOString()}
              class="text-muted order-first flex items-center text-base"
            >
              <span class="bg-edge h-4 w-0.5 rounded-full"></span>
              <span class="ml-3">{formatDate(date)}</span>
            </time>
            {
              tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <a
                      href={`/blog/tag/${slugify(tag)}/`}
                      class="bg-pill text-body hover:bg-edge inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium transition"
                    >
                      {tag}
                    </a>
                  ))}
                </div>
              )
            }
          </header>

          {
            series && seriesPosts.length > 1 && (
              <div class="border-hairline mt-8 rounded-2xl border p-6">
                <h2 class="text-heading text-sm font-semibold">Part of the "{series}" series</h2>
                <ol class="mt-4 space-y-2 text-sm">
                  {seriesPosts.map((post, index) => {
                    const currentOrder = seriesOrder ?? 0;
                    const isCurrent = post.order === currentOrder;
                    return (
                      <li class="flex items-center gap-3">
                        <span
                          class={`flex h-6 w-6 items-center justify-center rounded-full text-xs font-medium ${isCurrent ? 'bg-emission text-on-solid' : 'bg-pill text-subtle'}`}
                        >
                          {index + 1}
                        </span>
                        {isCurrent ? (
                          <span class="text-heading font-medium">{post.title}</span>
                        ) : (
                          <a href={`/blog/${post.slug}/`} class="text-body hover:text-link">
                            {post.title}
                          </a>
                        )}
                      </li>
                    );
                  })}
                </ol>
              </div>
            )
          }

          <Prose class="mt-8" data-mdx-content>
            <slot />
          </Prose>
        </article>
      </div>
    </div>
  </Container>
</BaseLayout>
