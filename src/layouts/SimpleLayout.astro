---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/Container.astro';

interface Props {
  title: string;
  intro: string;
  description?: string;
  /** Forwarded to BaseLayout — 'profile' emits ProfilePage structured data */
  type?: 'website' | 'article' | 'profile';
}

const { title, intro, description, type } = Astro.props;
---

<BaseLayout title={title} description={description || intro} type={type}>
  <Container class="mt-16 sm:mt-32">
    <header class="max-w-2xl">
      <h1 class="text-heading text-4xl font-bold tracking-tight sm:text-5xl">
        {title}
      </h1>
      <p class="text-body mt-6 text-base">
        {intro}
      </p>
    </header>
    <div class="mt-16 sm:mt-20">
      <slot />
    </div>
  </Container>
</BaseLayout>
