---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Self-hosted fonts (no third-party Google Fonts request). Newsreader as a
// variable font with the optical-size axis (matches the old opsz 6..72), plus
// IBM Plex Mono at the three weights the design system uses.
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/tailwind.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'James Brink - SRE/DevOps Engineer, infrastructure automator, and astrophotographer.',
  image = '/images/og.png',
} = Astro.props;
const siteTitle = title === 'Home' ? 'James Brink' : `${title} - James Brink`;

// Absolute URLs for canonical + social cards (Astro.site = https://jamesbrink.online)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'James Brink',
  url: Astro.site?.toString(),
  image: ogImageURL.toString(),
  jobTitle: 'Site Reliability / DevOps Engineer',
  description,
  sameAs: [
    'https://github.com/jamesbrink',
    'https://linkedin.com/in/brinkjames',
    'https://twitter.com/brinkoo7',
    'https://bsky.app/profile/jamesbrink.bsky.social',
    'https://medium.com/@jamesbrink',
    'https://instagram.com/brink.james/',
  ],
};
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="James Brink" />
    <title>{siteTitle}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="James Brink" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="James Brink — SRE/DevOps Engineer" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@brinkoo7" />
    <meta name="twitter:creator" content="@brinkoo7" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Fonts self-hosted via Fontsource (imported in the layout frontmatter). -->

    <!-- Theme initialization (prevents flash). Dark-first: default dark;
         only add `.light` when the visitor has explicitly chosen light. -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.add('light');
          }
        } catch {
          /* localStorage unavailable; keep default (dark) theme */
        }
      })();
    </script>
  </head>
  <body class="bg-page flex h-full font-sans antialiased">
    <!-- Background decoration: starfield + nebula bloom band, then the
         centered content panel (opaque, covers the field centrally). -->
    <div class="fixed inset-0 flex justify-center sm:px-8">
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[640px]"
        style="background: var(--field-stars)"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[640px]"
        style="background: var(--nebula-bloom)"
      >
      </div>
      <div class="flex w-full max-w-7xl lg:px-8">
        <div class="ring-hairline bg-card w-full ring-1"></div>
      </div>
    </div>

    <div class="relative flex w-full flex-col">
      <Header />
      <main class="flex-auto">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "f12cb510c5614d41a88322048951db3f"}'></script>
  </body>
</html>
