---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Self-hosted fonts (no third-party Google Fonts request). Newsreader as a
// variable font with the optical-size axis (matches the old opsz 6..72), plus
// IBM Plex Mono at the three weights the design system uses.
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/tailwind.css';
import { IDENTITY, profileUrls } from '../data/profiles';

interface Props {
  title: string;
  description?: string;
  image?: string;
  /** 'article' emits BlogPosting schema + article OG tags; 'profile' emits ProfilePage schema */
  type?: 'website' | 'article' | 'profile';
  publishDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description = 'James Brink - SRE/DevOps Engineer, infrastructure automator, and astrophotographer.',
  image = '/images/og.jpg',
  type = 'website',
  publishDate,
  updatedDate,
  tags = [],
  noindex = false,
} = Astro.props;
const siteTitle = title === 'Home' ? 'James Brink — SRE/DevOps Engineer' : `${title} - James Brink`;

// Absolute URLs for canonical + social cards (Astro.site = https://jamesbrink.online)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
// The default card and generated post cards are 1200x630; hero images have unknown dimensions.
const hasKnownOgDims = image === '/images/og.jpg' || image.startsWith('/blog/og/');

const personId = new URL('/#person', Astro.site).toString();

const personSchema = {
  '@type': 'Person',
  '@id': personId,
  name: IDENTITY.name,
  givenName: IDENTITY.givenName,
  familyName: IDENTITY.familyName,
  url: Astro.site?.toString(),
  image: new URL('/images/avatar.jpg', Astro.site).toString(),
  jobTitle: IDENTITY.jobTitle,
  description: IDENTITY.bio,
  knowsAbout: IDENTITY.knowsAbout,
  sameAs: profileUrls,
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': new URL('/#website', Astro.site).toString(),
  name: IDENTITY.name,
  url: Astro.site?.toString(),
  publisher: { '@id': personId },
};

const graph: Record<string, unknown>[] = [personSchema, websiteSchema];

if (type === 'article' && publishDate) {
  graph.push({
    '@type': 'BlogPosting',
    headline: title,
    description,
    url: canonicalURL.toString(),
    mainEntityOfPage: canonicalURL.toString(),
    image: ogImageURL.toString(),
    datePublished: publishDate.toISOString(),
    dateModified: (updatedDate ?? publishDate).toISOString(),
    ...(tags.length > 0 && { keywords: tags.join(', ') }),
    author: { '@id': personId },
    publisher: { '@id': personId },
  });
}

if (type === 'profile') {
  graph.push({
    '@type': 'ProfilePage',
    url: canonicalURL.toString(),
    mainEntity: { '@id': personId },
  });
}

const structuredData = { '@context': 'https://schema.org', '@graph': graph };
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="James Brink" />
    <title>{siteTitle}</title>
    {
      noindex ? (
        <meta name="robots" content="noindex" />
      ) : (
        <link rel="canonical" href={canonicalURL} />
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="James Brink — RSS Feed"
      href="/rss.xml"
    />

    <!-- Identity: machine-readable claim that these profiles are the same person -->
    {profileUrls.map((url) => <link rel="me" href={url} />)}

    <!-- Open Graph -->
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:site_name" content="James Brink" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    {hasKnownOgDims && <meta property="og:image:width" content="1200" />}
    {hasKnownOgDims && <meta property="og:image:height" content="630" />}
    <meta
      property="og:image:alt"
      content={type === 'article'
        ? `Card for the article "${title}" by James Brink`
        : 'James Brink — SRE/DevOps Engineer'}
    />
    {
      type === 'article' && publishDate && (
        <meta property="article:published_time" content={publishDate.toISOString()} />
      )
    }
    {
      type === 'article' && updatedDate && (
        <meta property="article:modified_time" content={updatedDate.toISOString()} />
      )
    }
    {
      /* OG spec: article:author is a profile URL, not a display name */
      type === 'article' && (
        <meta property="article:author" content={new URL('/about/', Astro.site).toString()} />
      )
    }
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@brinkoo7" />
    <meta name="twitter:creator" content="@brinkoo7" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data: Person + WebSite (+ BlogPosting / ProfilePage per page type) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Fonts self-hosted via Fontsource (imported in the layout frontmatter). -->

    <!-- Theme initialization (prevents flash). Dark-first: default dark;
         only add `.light` when the visitor has explicitly chosen light. -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.add('light');
          }
        } catch {
          /* localStorage unavailable; keep default (dark) theme */
        }
      })();
    </script>
  </head>
  <body class="bg-page flex h-full font-sans antialiased">
    <!-- Background decoration: starfield + nebula bloom band, then the
         centered content panel (opaque, covers the field centrally). -->
    <div class="fixed inset-0 flex justify-center sm:px-8">
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[640px]"
        style="background: var(--field-stars)"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[640px]"
        style="background: var(--nebula-bloom)"
      >
      </div>
      <div class="flex w-full max-w-7xl lg:px-8">
        <div class="ring-hairline bg-card w-full ring-1"></div>
      </div>
    </div>

    <div class="relative flex w-full flex-col">
      <Header />
      <main class="flex-auto">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "f12cb510c5614d41a88322048951db3f"}'></script>
  </body>
</html>
